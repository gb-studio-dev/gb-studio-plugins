 // ============================================================
+// Metatile collision — current scene (SRAM lookup)
+// ============================================================
+
+// Iterate over y range using current scene's SRAM metatile collision table.
+// Handles bottom-edge OOB: passthrough if continuous DOWN, wall otherwise.
+static UBYTE metatile_col_test_y(UBYTE tile_mask, UBYTE tx, UBYTE ty_start, UBYTE ty_end) {
+#if METATILE_SIZE == METATILE_SIZE_16
+    UBYTE metatile_x_offset = METATILE_X_OFFSET(tx);
+    UBYTE tile_x_offset = TILE_X_OFFSET(tx);
+#endif
+    UBYTE inc = UBYTE_LESS_THAN(ty_start, ty_end);
+    UBYTE tile;
+    while (TRUE) {
+#if METATILE_SIZE == METATILE_SIZE_16
+        tile = sram_collision_data[get_metatile_tile(metatile_x_offset + METATILE_Y_OFFSET(tile_hit_y), tile_x_offset + TILE_Y_OFFSET(tile_hit_y))];
+#else
+        tile = sram_collision_data[sram_map_data[METATILE_MAP_OFFSET(tx, tile_hit_y)]];
+#endif
+        if (tile & tile_mask) return tile;
+        if (tile_hit_y == ty_end) break;
+        if (inc) tile_hit_y++;
+        else     tile_hit_y--;
+        if (tile_hit_y >= image_tile_height) {
+            if (continuous_scene_enabled & DIRECTION_BOTTOM_FLAG) return 0;
+            return COLLISION_ALL & tile_mask ? COLLISION_ALL : 0;
+        }
+    }
+    return 0;
+}
+
+// Iterate over x range using current scene's SRAM metatile collision table.
+// Handles right-edge OOB: passthrough if continuous RIGHT, wall otherwise.
+static UBYTE metatile_col_test_x(UBYTE tile_mask, UBYTE ty, UBYTE tx_start, UBYTE tx_end) {
+    UWORD metatile_y_offset = METATILE_Y_OFFSET(ty);
+#if METATILE_SIZE == METATILE_SIZE_16
+    UBYTE tile_y_offset = TILE_Y_OFFSET(ty);
+#endif
+    UBYTE inc = UBYTE_LESS_THAN(tx_start, tx_end);
+    UBYTE tile;
+    while (TRUE) {
+#if METATILE_SIZE == METATILE_SIZE_16
+        tile = sram_collision_data[get_metatile_tile(metatile_y_offset + METATILE_X_OFFSET(tile_hit_x), tile_y_offset + TILE_X_OFFSET(tile_hit_x))];
+#else
+        tile = sram_collision_data[sram_map_data[(metatile_y_offset + tile_hit_x)]];
+#endif
+        if (tile & tile_mask) return tile;
+        if (tile_hit_x == tx_end) break;
+        if (inc) tile_hit_x++;
+        else     tile_hit_x--;
+        if (tile_hit_x >= image_tile_width) {
+            if (continuous_scene_enabled & DIRECTION_RIGHT_FLAG) return 0;
+            return COLLISION_ALL & tile_mask ? COLLISION_ALL : 0;
+        }
+    }
+    return 0;
+}
+
+// ============================================================
+// Metatile collision — neighbor scene (ROM lookup via continuous scene)
+// ============================================================
+
+// Iterate over y range in a neighbor scene's metatile collision (ROM tilemap -> SRAM table).
+// neighbor_tx: already-translated x coordinate in the neighbor scene's tile space.
+// y_offset: added to tile_hit_y each iteration to translate to the neighbor's y space.
+static UBYTE neighbor_metatile_col_test_y(UBYTE tile_mask, continuous_scene_t* cs,
+                                           UBYTE neighbor_tx, BYTE y_offset,
+                                           UBYTE ty_start, UBYTE ty_end) {
+    UBYTE inc = UBYTE_LESS_THAN(ty_start, ty_end);
+    UBYTE tile;
+    while (TRUE) {
+        tile = get_neighbor_metatile_collision(cs, neighbor_tx, (UBYTE)(tile_hit_y + y_offset));
+        if (tile & tile_mask) return tile;
+        if (tile_hit_y == ty_end) break;
+        if (inc) tile_hit_y++;
+        else     tile_hit_y--;
+    }
+    return 0;
+}
+
+// Iterate over x range in a neighbor scene's metatile collision (ROM tilemap -> SRAM table).
+// neighbor_ty: already-translated y coordinate in the neighbor scene's tile space.
+// x_offset: added to tile_hit_x each iteration to translate to the neighbor's x space.
+static UBYTE neighbor_metatile_col_test_x(UBYTE tile_mask, continuous_scene_t* cs,
+                                           UBYTE neighbor_ty, BYTE x_offset,
+                                           UBYTE tx_start, UBYTE tx_end) {
+    UBYTE inc = UBYTE_LESS_THAN(tx_start, tx_end);
+    UBYTE tile;
+    while (TRUE) {
+        tile = get_neighbor_metatile_collision(cs, (UBYTE)(tile_hit_x + x_offset), neighbor_ty);
+        if (tile & tile_mask) return tile;
+        if (tile_hit_x == tx_end) break;
+        if (inc) tile_hit_x++;
+        else     tile_hit_x--;
+    }
+    return 0;
+}
