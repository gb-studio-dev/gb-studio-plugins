{
  "type": "enginePlugin",
  "name": "Extended Scene Stack Plugin",
  "author": "Mico27",
  "url": "https://github.com/Mico27/gbs-SceneStackExPlugin",
  "description": "Saving the scene in stack in GBStudio only saves the scene address and the Player position into the stack. This plugin adds an extanded version saving the scene to the stack which puts pretty much everything from the scene.",
  "license": "MIT",
  "version": "4.3.0",
  "gbsVersion": ">=4.3.0",
  "order": -9,
  "engineAltRules": [
    {
      "when": {
        "additionalPlugins": [
          "Mico27/ScreenScrollPlugin",
          "Mico27/MetaTilePlugin"
        ]
      },
      "use": "Scr_M"
    },
    {
      "when": {
        "additionalPlugins": [
          "ScreenScrollPlugin",
          "MetaTilePlugin"
        ]
      },
      "use": "Scr_M"
    },
    {
      "when": {
        "additionalPlugins": [
          "Mico27/MetaTilePlugin"
        ]
      },
      "use": "M"
    },
    {
      "when": {
        "additionalPlugins": [
          "MetaTilePlugin"
        ]
      },
      "use": "M"
    },
    {
      "when": {
        "additionalPlugins": [
          "Mico27/ScreenScrollPlugin"
        ]
      },
      "use": "Scr"
    },
    {
      "when": {
        "additionalPlugins": [
          "ScreenScrollPlugin"
        ]
      },
      "use": "Scr"
    }
  ]
}