+// Read a single tile's collision byte from a neighbor scene's banked collision ROM.
+// Returns COLLISION_ALL when tx/ty are out of the neighbor's bounds.
+static UBYTE get_neighbor_collision(continuous_scene_t* cs, UBYTE tx, UBYTE ty) {
+    if (!cs->collision.ptr || !cs->collision.bank) return COLLISION_ALL;
+    if (tx >= cs->tile_width || ty >= cs->tile_height) return COLLISION_ALL;
+    return ReadBankedUBYTE((const UBYTE*)cs->collision.ptr + ((UWORD)ty * cs->tile_width + tx), cs->collision.bank);
+}
 
