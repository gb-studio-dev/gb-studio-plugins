{
  "type": "enginePlugin",
  "name": "Append load Text Plugin",
  "author": "Mico27",
  "url": "https://github.com/Mico27/gbs-AppendLoadTextPlugin",
  "description": "Allows appending text to already loaded text before displaying it. Also adds more granular text options events",
  "license": "MIT",
  "version": "4.3.0",
  "gbsVersion": ">=4.3.0",
  "order": -1,
  "engineAltRules": [
    {
      "when": {
        "additionalPlugins": [
          "Mico27/ContinuousScenePlugin",
          "Mico27/ScreenScrollPlugin",
          "Mico27/MetaTilePlugin"
        ]
      },
      "use": "Cont_Scr_M"
    },
    {
      "when": {
        "additionalPlugins": [
          "ContinuousScenePlugin",
          "ScreenScrollPlugin",
          "MetaTilePlugin"
        ]
      },
      "use": "Cont_Scr_M"
    },
    {
      "when": {
        "additionalPlugins": [
          "Mico27/ContinuousScenePlugin",
          "Mico27/MetaTilePlugin"
        ]
      },
      "use": "Cont_M"
    },
    {
      "when": {
        "additionalPlugins": [
          "ContinuousScenePlugin",
          "MetaTilePlugin"
        ]
      },
      "use": "Cont_M"
    },
    {
      "when": {
        "additionalPlugins": [
          "Mico27/ContinuousScenePlugin",
          "Mico27/ScreenScrollPlugin"
        ]
      },
      "use": "Cont_Scr"
    },
    {
      "when": {
        "additionalPlugins": [
          "ContinuousScenePlugin",
          "ScreenScrollPlugin"
        ]
      },
      "use": "Cont_Scr"
    },
    {
      "when": {
        "additionalPlugins": [
          "Mico27/ScreenScrollPlugin",
          "Mico27/MetaTilePlugin"
        ]
      },
      "use": "Scr_M"
    },
    {
      "when": {
        "additionalPlugins": [
          "ScreenScrollPlugin",
          "MetaTilePlugin"
        ]
      },
      "use": "Scr_M"
    },
    {
      "when": {
        "additionalPlugins": [
          "Mico27/ContinuousScenePlugin"
        ]
      },
      "use": "Cont"
    },
    {
      "when": {
        "additionalPlugins": [
          "ContinuousScenePlugin"
        ]
      },
      "use": "Cont"
    },
    {
      "when": {
        "additionalPlugins": [
          "Mico27/MetaTilePlugin"
        ]
      },
      "use": "M"
    },
    {
      "when": {
        "additionalPlugins": [
          "MetaTilePlugin"
        ]
      },
      "use": "M"
    },
    {
      "when": {
        "additionalPlugins": [
          "Mico27/ScreenScrollPlugin"
        ]
      },
      "use": "Scr"
    },
    {
      "when": {
        "additionalPlugins": [
          "ScreenScrollPlugin"
        ]
      },
      "use": "Scr"
    }
  ]
}